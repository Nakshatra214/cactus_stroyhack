# ============================================
# StoryHack: Agentic Video Editor
# Environment Variables
# ============================================

# --- App ---
APP_NAME=StoryHack Agentic Editor
DEBUG=true

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://storyhack:storyhack@localhost:5432/storyhack

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# --- Stability AI (Stable Diffusion) ---
STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- ElevenLabs (Optional) ---
ELEVENLABS_API_KEY=

# --- Storage ---
UPLOAD_DIR=storage/uploads
MEDIA_DIR=storage/media
VIDEO_DIR=storage/videos
